{
  "name": "life-copilot-website",
  "description": "Documentation and specification site for the Life Copilot app",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "packageManager": "bun@1.3.4",
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.server": "vite build -c adapters/cloudflare-pages/vite.config.ts",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "bun run build && bun run build.server && wrangler pages deploy dist",
    "serve": "wrangler pages dev dist",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview --open",
    "start": "vite --open --mode ssr",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.19.0",
    "@builder.io/qwik-city": "^1.19.0",
    "@cloudflare/workers-types": "^4.0.0",
    "@eslint/js": "^9.32.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "20.19.0",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.19.0",
    "flyonui": "^2.4.1",
    "globals": "16.4.0",
    "prettier": "latest",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.38.0",
    "typescript-plugin-css-modules": "5.2.0",
    "undici": "*",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1",
    "wrangler": "^3.0.0"
  }
}
