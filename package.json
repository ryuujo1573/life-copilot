{
  "name": "life-copilot-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "website"
  ],
  "scripts": {
    "dev": "vite",
    "start": "tauri dev",
    "build": "tsc && vite build",
