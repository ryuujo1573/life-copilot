    "lint:website": "bun run --cwd website lint",
    "lint:app": "oxlint"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "flyonui": "^2",
    "globals": "^16.4.0",
    "oxlint": "^1.51.0",
    "tailwindcss": "^4",
    "typescript": "~5.4",
    "typescript-eslint": "^8.38.0",
    "vite": "^6"
  }
